#Algolia Configuration
ALGOLIA_APP_ID=T9C141VWHW
ALGOLIA_SEARCH_API_KEY=cbf45e9f74194fe5048ce622a20a78fd
ALGOLIA_WRITE_API_KEY=3504ebe9ef33d9a77418f1c60f7f2f0e
ALGOLIA_INDEX_NAME=products
ALGOLIA_INSIGHTS_REGION=us
# PostgreSQL Database Configuration
PGUSER=trinity_user
PGPASSWORD=trinity123
PGDATABASE=trinity_grocery
PGHOST=localhost
PGPORT=5432

# Flask Configuration
DATABASE_URL=postgresql+psycopg2://trinity_user:trinity123@localhost:5432/trinity_grocery
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production
FLASK_ENV=development

# Application Port
PORT=5000

# PayPal Configuration
# Local dev without PayPal keys: set PAYPAL_MOCK_MODE=true and restart Flask.
# The app will skip the real PayPal site and complete capture on the server.
PAYPAL_MOCK_MODE=true
#
# Real sandbox (https://developer.paypal.com → Apps & Credentials → Sandbox):
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_CURRENCY=USD

# Docker image (for production compose)
DOCKER_IMAGE=dockerhub_user/trinity-grocery-api:latest

# Docker Hub Credentials (for GitHub Actions only)
# Set these in GitHub Secrets, not in this file
# DOCKER_USERNAME=your_docker_username
# DOCKER_PASSWORD=your_docker_password

# AWS EC2 SSH Credentials (for GitHub Actions only)
# Set these in GitHub Secrets, not in this file
# EC2_HOST=your-ec2-ip-or-domain
# EC2_USER=ec2-user
# SSH_PRIVATE_KEY=your-private-key-content
