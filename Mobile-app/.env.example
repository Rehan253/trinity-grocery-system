# Copy to `.env` in this folder and adjust for your machine.
# Restart Expo after changing.

# Flask backend (no trailing slash)
# Simulator (iOS): http://127.0.0.1:5000
# Android emulator: http://10.0.2.2:5000
# Physical phone: http://YOUR_LAN_IP:5000
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:5000
